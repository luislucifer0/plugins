VertexLitGeneric
{
	$baseTexture "models\infected\haggard/hulk_01"
	$bumpmap "models\infected\haggard\hulk_01_normal"

	$phongboost 1
	$phongexponent 1
	$phongfresnelranges "[0 2 30]"
	$BASEMAPLUMINANCEPHONGMASK 1
	$phong 0
	"GPU>=2?$phong" 1

	"$detail" "effects/burned.vtf"
	"$seamless_detail" "1"
	"$seamless_scale" ".005"
	"$detailscale" "4"
	"$detailblendfactor" .001	// effectively turns the burn off in hlmv.  need something non-zero to enable it in-game though.
	"$detailblendmode" 2
	//bbqamount sets the darkness of the skin due to cooking - 0 = black, 1 = normal.  Best to cap min around .3?
	//1
	"$bbqamount" ".3"	
	//BurnLevel sets the bright fire on the skin.  0 = none, 1 = full.  Best to top out around .9.
	//0
	"$BurnLevel" ",9"

	"Proxies"
	{
		"BBQLevel"
		{
			"resultVar" "$bbqamount" 
		}

		"BurnLevel"
		{
			"resultVar" "$burnlevel"
		}

		"Multiply"
		{
			"srcVar1" "$phongfresnelrange_0" 
			"srcVar2" "$bbqamount" 
			"resultVar" "$phongfresnelranges[0]"
		}
		"Multiply"
		{
			"srcVar1" "$phongfresnelrange_1" 
			"srcVar2" "$bbqamount" 
			"resultVar" "$phongfresnelranges[1]"
		}
		"Multiply"
		{
			"srcVar1" "$phongfresnelrange_2" 
			"srcVar2" "$bbqamount" 
			"resultVar" "$phongfresnelranges[2]"
		}
		"Equals"
		{
			"srcVar1" "$BurnLevel" 
			"resultVar" "$detailblendfactor"
		}

	}

}
